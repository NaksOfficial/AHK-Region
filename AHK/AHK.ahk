SelectArticle() {
    global currentCode
    if (currentCode = "UK")
        SelectArticleUK()
    else if (currentCode = "KOAP")
        SelectArticleKOAP()
    else
        SelectArticleUPK()
}

SelectArticleUK() {
    global ukArticles, ArticleList, SavedList, savedArticles
    selected := ArticleList.Text
    if !selected
        return
    for article in ukArticles {
        if (selected = article.article ", " article.title) {
            for saved in savedArticles {
                if (saved.article = article.article && saved.title = article.title)
                    return
            }
            formattedText := article.article " - " article.title
            if (article.description != "")
                formattedText .= "`n(" article.description ")"
            if (article.jail_max > 0)
                formattedText .= "`nЛишение свободы: " article.jail_max " лет"
            if (article.fine > 0)
                formattedText .= "`nШтраф: " article.fine " руб."
            if (article.punishment != "")
                formattedText .= "`nНаказание: " article.punishment
            formattedText .= "`n----------------"
            SavedList.Value .= FormatTextForWrapping(formattedText) "`n"
            savedArticles.Push(article)
            UpdateStars()
            return
        }
    }
}

