RemoveArticle() {
    global ArticleList, savedArticles
    selected := ArticleList.Text
    if !selected
        return
    newSaved := []
    for article in savedArticles {
        if (article.article ", " article.title != selected)
            newSaved.Push(article)
    }
    savedArticles := newSaved
    UpdateSavedList()
    UpdateStars()
}

RemoveArticleFromSaved() {
    global SavedList, savedArticles
    selected := SavedList.Text
    if !selected
        return
    firstLine := StrSplit(selected, "`n")[1]
    parts := StrSplit(firstLine, " - ")
    if parts.Length < 2
        return
    artNum := parts[1]
    artTitle := parts[2]
    newSaved := []
    for article in savedArticles {
        if (article.article != artNum || article.title != artTitle)
            newSaved.Push(article)
    }
    savedArticles := newSaved
    UpdateSavedList()
    UpdateStars()
}

UpdateSavedList() {
    global SavedList, savedArticles
    SavedList.Value := ""
    for article in savedArticles {
        text := article.article " - " article.title
        if (article.description != "")
            text .= "`n(" article.description ")"
        if (article.jail_max > 0) {
            if (article.codex = "KOAP") {
                text .= "`nАдминистративный арест: " article.jail_max " суток"
            } else {
                text .= "`nЛишение свободы: " article.jail_max " лет"
            }
        }
        if (article.fine > 0)
            text .= "`nШтраф: " article.fine " руб."
        if (article.punishment != "")
            text .= "`nНаказание: " article.punishment
        text .= "`n----------------"
        SavedList.Value .= FormatTextForWrapping(text) "`n"
    }
}

FormatTextForWrapping(text) {
    global SavedList
    x := y := w := h := 0
    SavedList.GetPos(&x, &y, &w, &h)
    static fontWidth := GetAverageFontWidth(SavedList)
    maxWidth := Floor((w - 20) / fontWidth)
    newText := ""
    lines := StrSplit(text, "`n")
    for each, line in lines {
        words := StrSplit(line, " ")
        newLine := ""
        for each, word in words {
            if (StrLen(newLine) + StrLen(word) + 1 > maxWidth) {
                newText .= Trim(newLine) . "`n"
                newLine := word
            } else {
                if (newLine != "")
                    newLine .= " "
                newLine .= word
            }
        }
        newText .= Trim(newLine) . "`n"
    }
    return RTrim(newText, "`n")
}

GetAverageFontWidth(control) {
    hWnd := control.Hwnd
    if (!hWnd)
        return 7
    hFont := DllCall("SendMessage", "Ptr", hWnd, "UInt", 0x31, "Ptr", 0, "Ptr", 0, "Ptr")
    if (!hFont)
        return 7
    hDC := DllCall("GetDC", "Ptr", hWnd, "Ptr")
    if (!hDC)
        return 7
    oldFont := DllCall("SelectObject", "Ptr", hDC, "Ptr", hFont, "Ptr")
    if (!oldFont) {
        DllCall("ReleaseDC", "Ptr", hWnd, "Ptr", hDC)
        return 7
    }
    SIZE := Buffer(8)
    textSample := "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyzАБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯабвгдеёжзийклмнопрстуфхцчшщъыьэюя0123456789()[]{}.,-;:"
    if (!DllCall("GetTextExtentPoint32", "Ptr", hDC, "Str", textSample, "Int", StrLen(textSample), "Ptr", SIZE)) {
        DllCall("SelectObject", "Ptr", hDC, "Ptr", oldFont)
        DllCall("ReleaseDC", "Ptr", hWnd, "Ptr", hDC)
        return 7
    }
    width := NumGet(SIZE, 0, "Int") // StrLen(textSample)
    DllCall("SelectObject", "Ptr", hDC, "Ptr", oldFont)
    DllCall("ReleaseDC", "Ptr", hWnd, "Ptr", hDC)
    return width
}

