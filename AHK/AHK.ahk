SendText() {
    global user_jeton
    if (RegExMatch(Trim(user_jeton), "^(/todo|/me)")) {
        A_Clipboard := user_jeton
    } else {
        A_Clipboard := "/do " . user_jeton
    }
    if !ClipWait(2) {
        MsgBox "При отправке жетона возникла ошибка: текст не скопировался в буфер!", "Ошибка", 0x10
        return
    }
    SetKeyDelay 50, 50
    Send "tе"
    Sleep 100
    Send "^a{Delete}"
    Sleep 50
    Send "^v"
    Sleep 50
    Send "{Enter}{Enter}"
}

