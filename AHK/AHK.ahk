; ============================================================
; АВТОМАТИЧЕСКОЕ ОБНОВЛЕНИЕ ЧЕРЕЗ GITHUB
; ============================================================
global currentVersion := "2.0"
global githubRawUrl := "https://raw.githubusercontent.com/ВАШ_АККАУНТ/AHK-Region/main/AHK/"
global versionUrl := githubRawUrl . "Version.txt"
global scriptUrl := githubRawUrl . "FSB1-8o.ahk"

CheckForUpdates() {
    global currentVersion, versionUrl, scriptUrl
    
    if A_Args.Length > 0 && A_Args[1] = "/updated" {
        MsgBox("✅ Скрипт успешно обновлён до версии " currentVersion, "Обновление", 0x40)
        return
    }
    
    try {
        tempFile := A_Temp "\version_check.txt"
        Download(versionUrl, tempFile)
        latestVersion := Trim(FileRead(tempFile))
        FileDelete(tempFile)
        
        if (latestVersion != "" && latestVersion != currentVersion) {
            result := MsgBox("📢 Доступна новая версия!`n`n" .
                "Текущая: " currentVersion "`nНовая: " latestVersion "`n`n" .
                "Обновить сейчас?", "Доступно обновление", 0x24)
            
            if (result = "Yes") {
                newScriptPath := A_Temp "\FSB1-8o_updated.ahk"
                Download(scriptUrl, newScriptPath)
                batPath := A_Temp "\update.bat"
                batContent := "@echo off`n"
                batContent .= "timeout /t 2 /nobreak >nul`n"
                batContent .= "copy /Y `"" newScriptPath "`" `"" A_ScriptFullPath "`" >nul`n"
                batContent .= "start `"`" `"" A_ScriptFullPath "`" /updated`n"
                batContent .= "del `"" newScriptPath "`" >nul 2>nul`n"
                batContent .= "del `"" batPath "`" >nul 2>nul`n"
                FileAppend(batContent, batPath, "UTF-8")
                Run(batPath, , "Hide")
                ExitApp()
            }
        }
    } catch as err {
        ; Нет интернета — игнорируем
    }
}

ManualUpdateCheck() {
    CheckForUpdates()
}

; Запускаем проверку
CheckForUpdates()

; ============================================================
; Глобальные переменные
; ============================================================
global screenWidth := A_ScreenWidth
global screenHeight := A_ScreenHeight

global searchGuiWidth := screenWidth * 0.3
global searchGuiHeight := screenHeight * 0.6

global savedGuiWidth := screenWidth * 0.4
global savedGuiHeight := screenHeight * 0.6

global starsGuiWidth := screenWidth * 0.2
global starsGuiHeight := screenHeight * 0.6

global currentCode := "UK"

global ukArticles := [], koapArticles := [], upkArticles := [], savedArticles := []

; ============================================================
; Функция для обработки массивов статей
; ============================================================
ProcessArticles() {
    global ukArticles, koapArticles, upkArticles
    for art in ukArticles {
        art.codex := "UK"
        art.jail_max := 0
        if art.punishment && InStr(art.punishment, "лишение свободы") {
            if RegExMatch(art.punishment, "до\s+(\d+)\s+лет", &match) {
                art.jail_max := match[1]
            } else if RegExMatch(art.punishment, "от\s+\d+\s+до\s+(\d+)\s+лет", &match) {
                art.jail_max := match[1]
            }
        }
        if art.jail_max = 0 && art.jail > 0
            art.jail_max := art.jail
    }
    for art in koapArticles {
        art.codex := "KOAP"
        art.jail_max := art.jail
    }
    for art in upkArticles {
        art.codex := "UPK"
        art.jail_max := 0
    }
}

