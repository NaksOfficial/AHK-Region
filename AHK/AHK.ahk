UpdateStars() {
    global StarsList, savedArticles, TotalStarsText
    totalTimeUK := 0
    totalTimeKOAP := 0
    hasUK := false
    hasKOAP := false
    starsText := "Вменяемые статьи:`n"
    
    for article in savedArticles {
        if (article.codex = "UK") {
            suffix := " УК"
            if (article.jail_max > 0) {
                hasUK := true
                totalTimeUK += article.jail_max
            }
        } else if (article.codex = "KOAP") {
            suffix := " КоАП"
            if (article.jail_max > 0) {
                hasKOAP := true
                totalTimeKOAP += article.jail_max
            }
        } else if (article.codex = "UPK") {
            suffix := " УПК"
        } else {
            suffix := ""
        }
        starsText .= article.article . suffix . "`n"
    }
    
    StarsList.Value := starsText
    
    if (hasUK) {
        TotalStarsText.Value := "Суммарный срок: " totalTimeUK " лет"
    } else if (hasKOAP) {
        TotalStarsText.Value := "Суммарный срок: " totalTimeKOAP " суток"
    } else {
        TotalStarsText.Value := "Суммарный срок: нет срока"
    }
}


