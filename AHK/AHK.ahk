SwitchCode() {
    global CodeSelector, currentCode
    selected := CodeSelector.Text
    if (selected = "Уголовный Кодекс")
        currentCode := "UK"
    else if (selected = "Административный Кодекс")
        currentCode := "KOAP"
    else
        currentCode := "UPK"
    UpdateFilter()
}

UpdateFilter() {
    global currentCode, ArticleList
    ArticleList.Delete()
    if (currentCode = "UK")
        UpdateFilterUK()
    else if (currentCode = "KOAP")
        UpdateFilterKOAP()
    else
        UpdateFilterUPK()
}

UpdateFilterUK() {
    global ukArticles, ArticleList, SearchBox
    search := Trim(SearchBox.Value)
    search := StrLower(search)
    for article in ukArticles {
        text := StrLower(article.article " " article.title)
        if (search = "" or InStr(text, search)) {
            display := article.article ", " article.title
            ArticleList.Add([display])
        }
    }
}

