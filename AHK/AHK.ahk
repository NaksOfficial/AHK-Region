    }
    return IniRead(settingsFile, "Settings", bbb, "На груди висит жетон «МВД РФ | Уголовный Розыск | Булак | 01-й».")
}

ToggleOverlayNal() {
    static overlayGuiNal := ""
    if IsObject(overlayGuiNal) {
        overlayGuiNal.Destroy()
        overlayGuiNal := ""
    } else {
        overlayGuiNal := Gui("+AlwaysOnTop -Caption +ToolWindow +E0x20 +E0x80000 +LastFound")
        overlayGuiNal.BackColor := "000000"
        overlayGuiNal.MarginX := 0
        overlayGuiNal.MarginY := 0
        overlayGuiNal.Add("Picture", "x0 y0 w991 h671", "map.png")
        overlayGuiNal.Show("NoActivate")
        WinSetTransparent(230, overlayGuiNal.Hwnd)
    }
}

SendTextWatches() {
    A_Clipboard := '/do На руке командирские часы "Восток". Часы показывают ' . A_Hour . ':' . A_Min . ':' . A_Sec . '.'
    if !ClipWait(2) {
        MsgBox "Ошибка: текст не скопировался в буфер!", "Ошибка", 0x10
        return
    }
    SetKeyDelay 50, 50
    Send "tе"
    Sleep 100
    Send "^a{Delete}"
    Sleep 50
    Send "^v"
    Sleep 50
    Send "{Enter}{Enter}"
}