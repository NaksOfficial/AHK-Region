ukArticles := [
    ; ========== Глава 1. Задачи и принципы ==========
    { article: "1", title: "Уголовное законодательство Региональной Федерации", description: "1. Уголовное законодательство Региональной Федерации состоит из настоящего Уголовного кодекса и иных законов, принятых в соответствии с ним.`n2. Настоящий Кодекс определяет основания и принципы уголовной ответственности, виды преступлений и наказаний.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "2", title: "Задачи Уголовного кодекса", description: "1. Задачами настоящего Кодекса являются: охрана прав и свобод человека и гражданина, собственности, общественного порядка и общественной безопасности, окружающей среды, конституционного строя Региональной Федерации от преступных посягательств, обеспечение мира и безопасности человечества, а также предупреждение преступлений.`n2. Для осуществления этих задач настоящий Кодекс устанавливает основание и принципы уголовной ответственности, определяет, какие опасные для личности, общества или государства деяния признаются преступлениями, и устанавливает виды наказаний и иные меры уголовно-правового характера за совершение преступлений.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "3", title: "Принцип законности", description: "1. Преступность деяния, его наказуемость и иные уголовно-правовые последствия определяются только настоящим Кодексом.`n2. Лицо подлежит уголовной ответственности только за те деяния, которые признаны преступлениями на момент их совершения.`n3. Применение уголовного закона по аналогии не допускается.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "4", title: "Принцип равенства перед законом", description: "Лица, совершившие преступления, равны перед законом и подлежат уголовной ответственности независимо от пола, расы, национальности, языка, происхождения, имущественного и должностного положения, места жительства, отношения к религии, убеждений, принадлежности к общественным объединениям, а также других обстоятельств.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "5", title: "Принцип вины", description: "1. Лицо подлежит уголовной ответственности только за те общественно опасные действия (бездействие) и наступившие общественно опасные последствия, в отношении которых установлена его вина.`n2. Объективное вменение, то есть уголовная ответственность за невиновное причинение вреда, не допускается.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "6", title: "Принцип справедливости", description: "1. Наказание и иные меры уголовно-правового характера, применяемые к лицу, совершившему преступление, должны быть справедливыми, то есть соответствовать характеру и степени общественной опасности преступления, обстоятельствам его совершения и личности виновного.`n2. Никто не может нести уголовную ответственность дважды за одно и то же преступление.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "7", title: "Принцип гуманизма", description: "1. Уголовное законодательство Региональной Федерации обеспечивает безопасность человека.`n2. Наказание и иные меры уголовно-правового характера, применяемые к лицу, совершившему преступление, не могут иметь своей целью причинение физических страданий или унижение человеческого достоинства.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "8", title: "Основание уголовной ответственности", description: "Основанием уголовной ответственности является совершение деяния, содержащего все признаки состава преступления.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    ; ========== Глава 2. Действие Уголовного кодекса во времени и в пространстве ==========
    { article: "9", title: "Действие уголовного закона во времени", description: "1. Преступность и наказуемость деяния определяется законом, действовавшим во время его совершения.`n2. Закон, смягчающий наказание или устраняющий преступность деяния, имеет обратную силу.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "10", title: "Действие уголовного закона в пространстве", description: "1. Лица, совершившие преступления на территории Региональной Федерации, подлежат уголовной ответственности по настоящему Кодексу.`n2. Действие настоящего Кодекса распространяется на преступления, совершённые на всех территориях, находящихся под юрисдикцией Региональной Федерации.`n3. Должностное положение не освобождает от уголовной ответственности.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "11", title: "Обратная сила уголовного закона", description: "1. Уголовный закон, устраняющий преступность деяния, смягчающий наказание или иным образом улучшающий положение лица, совершившего преступление, имеет обратную силу, то есть распространяется на лиц, совершивших соответствующие деяния до вступления такого закона в силу, в том числе на лиц, отбывающих наказание или отбывших наказание, но имеющих судимость. Уголовный закон, устанавливающий преступность деяния, усиливающий наказание или иным образом ухудшающий положение лица, обратной силы не имеет.`n2. Если новый уголовный закон смягчает наказание за деяние, которое отбывается лицом, то это наказание подлежит сокращению в пределах, предусмотренных новым уголовным законом.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    ; ========== Глава 3. Преступление ==========
    { article: "12", title: "Категории преступлений", description: "1. В зависимости от характера и степени общественной опасности деяния, предусмотренные настоящим Кодексом, подразделяются на преступления небольшой тяжести, преступления средней тяжести, тяжкие преступления и особо тяжкие преступления.`n2. Преступлениями небольшой тяжести признаются умышленные и неосторожные деяния, за совершение которых максимальное наказание, предусмотренное настоящим Кодексом, не превышает трех лет лишения свободы.`n3. Преступлениями средней тяжести признаются умышленные деяния, за совершение которых максимальное наказание, предусмотренное настоящим Кодексом, не превышает шести лет лишения свободы, и неосторожные деяния, за совершение которых максимальное наказание, предусмотренное настоящим Кодексом, не превышает десяти лет лишения свободы.`n4. Тяжкими преступлениями признаются умышленные деяния, за совершение которых максимальное наказание, предусмотренное настоящим Кодексом, не превышает десяти лет лишения свободы, и неосторожные деяния, за совершение которых максимальное наказание, предусмотренное настоящим Кодексом, не превышает пятнадцати лет лишения свободы.`n5. Особо тяжкими преступлениями признаются умышленные деяния, за совершение которых настоящим Кодексом предусмотрено наказание в виде лишения свободы на срок свыше десяти лет или более строгое наказание.`n6. С учетом фактических обстоятельств преступления и степени его общественной опасности суд вправе при наличии смягчающих наказание обстоятельств и при отсутствии отягчающих наказание обстоятельств изменить категорию преступления на менее тяжкую, но не более чем на одну категорию преступления при условии, что за совершение преступления, указанного в части третьей настоящей статьи, осужденному назначено наказание, не превышающее трех лет лишения свободы, или другое более мягкое наказание; за совершение преступления, указанного в части четвертой настоящей статьи, осужденному назначено наказание, не превышающее пяти лет лишения свободы, или другое более мягкое наказание; за совершение преступления, указанного в части пятой настоящей статьи, осужденному назначено наказание, не превышающее семи лет лишения свободы.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "13", title: "Умышленная форма вины", description: "1. Преступление признаётся совершённым умышленно, если лицо осознавало общественную опасность своих действий и желало либо сознательно допускало наступление последствий.`n2. Умысел подразделяется на прямой и косвенный.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "14", title: "Неосторожная форма вины", description: "1. Преступление признаётся совершённым по неосторожности, если лицо не предвидело наступления последствий, хотя должно было и могло их предвидеть.`n2. Неосторожность выражается в форме легкомыслия либо небрежности.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "15", title: "Совершение преступления группой лиц", description: "1. Преступление признаётся совершённым группой лиц, если в его совершении участвовали два или более лица.`n2. Совершение преступления группой лиц является отягчающим обстоятельством, если иное не предусмотрено настоящим Кодексом.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "16", title: "Соучастие в преступлении", description: "1. Соучастием признаётся умышленное совместное участие двух или более лиц в совершении преступления.`n2. Соучастниками преступления наряду с исполнителем признаются организатор, подстрекатель и пособник.`n3. Исполнителем признается лицо, непосредственно совершившее преступление либо непосредственно участвовавшее в его совершении совместно с другими лицами (соисполнителями), а также лицо, совершившее преступление посредством использования других лиц, не подлежащих уголовной ответственности в силу возраста, невменяемости или других обстоятельств, предусмотренных настоящим Кодексом.`n4. Организатором признается лицо, организовавшее совершение преступления или руководившее его исполнением, а равно лицо, создавшее организованную группу или преступное сообщество (преступную организацию) либо руководившее ими.`n5. Подстрекателем признается лицо, склонившее другое лицо к совершению преступления путем уговора, подкупа, угрозы или другим способом.`n6. Пособником признается лицо, содействовавшее совершению преступления советами, указаниями, предоставлением информации, средств или орудий совершения преступления либо устранением препятствий, а также лицо, заранее обещавшее скрыть преступника, средства или орудия совершения преступления, следы преступления либо предметы, добытые преступным путем, а равно лицо, заранее обещавшее приобрести или сбыть такие предметы.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "17", title: "Оконченное и неоконченное преступление", description: "1. Преступление признаётся оконченным, если деяние содержит все признаки состава преступления.`n2. Неоконченным преступлением признаются приготовление к преступлению и покушение на преступление.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "18", title: "Приготовление к преступлению", description: "1. Приготовлением признаются умышленные действия, направленные на создание условий для совершения преступления.`n2. Уголовная ответственность за приготовление наступает только за тяжкие и особо тяжкие преступления.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "19", title: "Покушение на преступление", description: "1. Покушением признаются умышленные действия, непосредственно направленные на совершение преступления, если преступление не было доведено до конца по независящим от лица обстоятельствам.`n2. Ответственность за покушение наступает по статье, предусматривающей оконченное преступление, с учётом стадии.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "20", title: "Добровольный отказ от преступления", description: "1. Добровольным отказом от преступления признается прекращение лицом приготовления к преступлению либо прекращение действий (бездействия), непосредственно направленных на совершение преступления, если лицо осознавало возможность доведения преступления до конца.`n2. Лицо не подлежит уголовной ответственности за преступление, если оно добровольно и окончательно отказалось от доведения этого преступления до конца.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "21", title: "Совокупность преступлений", description: "1. Совокупностью преступлений признается совершение двух или более преступлений, ни за одно из которых лицо не было осуждено, за исключением случаев, когда совершение двух или более преступлений предусмотрено статьями Особенной части настоящего Кодекса в качестве обстоятельства, влекущего более строгое наказание. При совокупности преступлений лицо несет уголовную ответственность за каждое совершенное преступление по соответствующей статье или части статьи настоящего Кодекса.`n2. Совокупностью преступлений признается и одно действие (бездействие), содержащее признаки преступлений, предусмотренных двумя или более статьями настоящего Кодекса.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "22", title: "Рецидив преступлений", description: "1. Рецидивом преступлений признается совершение умышленного преступления лицом, имеющим судимость за ранее совершенное умышленное преступление.`n2. Рецидив преступлений влечет более строгое наказание на основании и в пределах, предусмотренных настоящим Кодексом, а также иные последствия, предусмотренные законодательством Региональной Федерации.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    ; ========== Глава 4. Обстоятельства, исключающие преступность деяния ==========
    { article: "23", title: "Необходимая оборона", description: "1. Не является преступлением причинение вреда посягающему лицу в состоянии необходимой обороны, то есть при защите личности и прав обороняющегося или других лиц, охраняемых законом интересов общества или государства от общественно опасного посягательства, если это посягательство было сопряжено с насилием, опасным для жизни обороняющегося или другого лица, либо с непосредственной угрозой применения такого насилия.`n2. Защита от посягательства, не сопряженного с насилием, опасным для жизни обороняющегося или другого лица, либо с непосредственной угрозой применения такого насилия, является правомерной, если при этом не было допущено превышения пределов необходимой обороны, то есть умышленных действий, явно не соответствующих характеру и опасности посягательства.`n2.1. Не являются превышением пределов необходимой обороны действия обороняющегося лица, если это лицо вследствие неожиданности посягательства не могло объективно оценить степень и характер опасности нападения.`n3. Положения настоящей статьи в равной мере распространяются на всех лиц независимо от их профессиональной или иной специальной подготовки и служебного положения, а также независимо от возможности избежать общественно опасного посягательства или обратиться за помощью к другим лицам или органам власти.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "24", title: "Причинение вреда при задержании лица, совершившего преступление", description: "1. Не является преступлением причинение вреда лицу, совершившему преступление, при его задержании для доставления органам власти и пресечения возможности совершения им новых преступлений, если иными средствами задержать такое лицо не представлялось возможным и при этом не было допущено превышения необходимых для этого мер.`n2. Превышением мер, необходимых для задержания лица, совершившего преступление, признается их явное несоответствие характеру и степени общественной опасности совершенного задерживаемым лицом преступления и обстоятельствам задержания, когда лицу без необходимости причиняется явно чрезмерный, не вызываемый обстановкой вред. Такое превышение влечет за собой уголовную ответственность только в случаях умышленного причинения вреда.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "25", title: "Крайняя необходимость", description: "1. Не является преступлением причинение вреда охраняемым уголовным законом интересам в состоянии крайней необходимости, то есть для устранения опасности, непосредственно угрожающей личности и правам данного лица или иных лиц, охраняемым законом интересам общества или государства, если эта опасность не могла быть устранена иными средствами и при этом не было допущено превышения пределов крайней необходимости.`n2. Превышением пределов крайней необходимости признается причинение вреда, явно не соответствующего характеру и степени угрожавшей опасности и обстоятельствам, при которых опасность устранялась, когда указанным интересам был причинен вред равный или более значительный, чем предотвращенный. Такое превышение влечет за собой уголовную ответственность только в случаях умышленного причинения вреда.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "26", title: "Физическое или психическое принуждение", description: "1. Не является преступлением причинение вреда охраняемым уголовным законом интересам в результате физического принуждения, если вследствие такого принуждения лицо не могло руководить своими действиями (бездействием).`n2. Вопрос об уголовной ответственности за причинение вреда охраняемым уголовным законом интересам в результате психического принуждения, а также в результате физического принуждения, вследствие которого лицо сохранило возможность руководить своими действиями, решается с учетом положений статьи 25 настоящего Кодекса.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "27", title: "Исполнение приказа или распоряжения", description: "1. Не является преступлением причинение вреда охраняемым уголовным законом интересам лицом, действующим во исполнение обязательных для него приказа или распоряжения. Уголовную ответственность за причинение такого вреда несет лицо, отдавшее незаконные приказ или распоряжение.`n2. Лицо, совершившее умышленное преступление во исполнение заведомо незаконных приказа или распоряжения, несет уголовную ответственность на общих основаниях. Неисполнение заведомо незаконных приказа или распоряжения исключает уголовную ответственность.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    ; ========== Глава 4. Наказание ==========
    { article: "28", title: "Понятие и цели наказания", description: "1. Наказание есть мера государственного принуждения, назначаемая по приговору суда. Наказание применяется к лицу, признанному виновным в совершении преступления, и заключается в предусмотренных настоящим Кодексом лишении или ограничении прав и свобод этого лица.`n2. Наказание применяется в целях восстановления социальной справедливости, а также в целях исправления осужденного и предупреждения совершения новых преступлений.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "29", title: "Виды наказаний", description: "Видами наказаний являются: а) штраф; б) лишение права занимать определенные должности или заниматься определенной деятельностью; в) лишение специального, воинского или почетного звания, классного чина и государственных наград; г) ограничение свободы; д) арест; е) лишение свободы на определенный срок;", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "30", title: "Основные и дополнительные виды наказаний", description: "1. Арест, содержание в дисциплинарной воинской части, лишение свободы на определенный срок применяются только в качестве основных видов наказаний.`n2. Штраф, лишение права занимать определенные должности или заниматься определенной деятельностью и ограничение свободы применяются в качестве как основных, так и дополнительных видов наказаний.`n3. Лишение специального, воинского или почетного звания, классного чина и государственных наград применяется только в качестве дополнительных видов наказаний.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "31", title: "Общие начала назначения наказания", description: "1. Лицу, признанному виновным в совершении преступления, назначается справедливое наказание в пределах, предусмотренных соответствующей статьей Особенной части настоящего Кодекса, и с учетом положений Общей части настоящего Кодекса. Более строгий вид наказания из числа предусмотренных за совершенное преступление назначается только в случае, если менее строгий вид наказания не сможет обеспечить достижение целей наказания.`n2. Более строгое наказание, чем предусмотрено соответствующими статьями Особенной части настоящего Кодекса за совершенное преступление, может быть назначено по совокупности преступлений в соответствии со статьями 12 и 22 настоящего Кодекса. Основания для назначения менее строгого наказания предусмотрены статьей 11 настоящего Кодекса.`n3. При назначении наказания учитываются характер и степень общественной опасности преступления и личность виновного, в том числе обстоятельства, смягчающие и отягчающие наказание, а также влияние назначенного наказания на исправление осужденного и на условия жизни его семьи.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "32", title: "Обстоятельства, смягчающие наказание", description: "1. Смягчающими обстоятельствами признаются: 1) совершение впервые преступления небольшой или средней тяжести вследствие случайного стечения обстоятельств; 2) совершение преступления в результате физического или психического принуждения либо в силу материальной, служебной или иной зависимости; 3) совершение преступления при нарушении условий правомерности необходимой обороны, задержания лица, совершившего преступление, крайней необходимости, исполнения приказа или распоряжения; 4) противоправность или аморальность поведения потерпевшего, явившегося поводом для преступления; 5) явка с повинной, активное способствование раскрытию и расследованию преступления, изобличению и уголовному преследованию других соучастников преступления, розыску имущества, добытого в результате преступления; 6) оказание медицинской и иной помощи потерпевшему непосредственно после совершения преступления, добровольное возмещение имущественного ущерба и морального вреда, причиненных в результате преступления, иные действия, направленные на заглаживание вреда, причиненного потерпевшему.`n2. Суд вправе признать смягчающими иные обстоятельства, не предусмотренные настоящим Кодексом, при условии их значимости для индивидуализации наказания.`n3. Если смягчающее обстоятельство предусмотрено соответствующей статьей Особенной части настоящего Кодекса в качестве признака преступления, оно само по себе не может повторно учитываться при назначении наказания.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "33", title: "Назначение наказания при наличии смягчающих обстоятельств", description: "1. При наличии смягчающих обстоятельств, предусмотренных пунктами 5 и (или) 6 части 1 статьи 32 настоящего Кодекса, и отсутствии отягчающих обстоятельств срок или размер наказания не могут превышать двух третей максимального срока или размера наиболее строгого вида наказания, предусмотренного соответствующей статьей Особенной части настоящего Кодекса.`n2. В случае заключения досудебного соглашения о сотрудничестве при наличии смягчающих обстоятельств, предусмотренных пунктом 5 части 1 статьи 32 настоящего Кодекса, и отсутствии отягчающих обстоятельств срок или размер наказания не могут превышать половины максимального срока или размера наиболее строгого вида наказания, предусмотренного соответствующей статьей Особенной части настоящего Кодекса.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "34", title: "Обстоятельства, отягчающие наказание", description: "1. Отягчающими обстоятельствами признаются: 1) рецидив преступлений; 2) наступление тяжких последствий в результате совершения преступления; 3) совершение преступления в составе группы лиц, группы лиц по предварительному сговору, организованной группы или преступного сообщества (преступной организации); 4) совершение преступления в условиях стихийного бедствия, чрезвычайного положения либо при иных чрезвычайных обстоятельствах; 5) совершение преступления в состоянии алкогольного, наркотического либо иного токсического опьянения, а равно уклонение от прохождения медицинского освидетельствования на состояние опьянения при наличии достаточных оснований полагать, что лицо находилось в таком состоянии.`n2. Суд, назначающий наказание, с учетом характера и степени общественной опасности совершенного преступления, а также личности виновного, вправе не признать обстоятельства, указанные в части 1 настоящей статьи, отягчающими.`n3. Если отягчающее обстоятельство предусмотрено соответствующей статьей Особенной части настоящего Кодекса в качестве признака преступления, оно само по себе не может повторно учитываться при назначении наказания.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "35", title: "Назначение наказания по совокупности преступлений", description: "1. При совокупности преступлений наказание назначается отдельно за каждое совершенное преступление.`n2. Если все преступления, совершенные по совокупности, являются преступлениями небольшой или средней тяжести, либо приготовлением к тяжкому или особо тяжкому преступлению, либо покушением на тяжкое или особо тяжкое преступление, окончательное наказание назначается путем поглощения менее строгого наказания более строгим либо путем частичного или полного сложения назначенных наказаний. При этом окончательное наказание не может превышать более чем наполовину максимальный срок или размер наказания, предусмотренного за наиболее тяжкое из совершенных преступлений.`n3. Если хотя бы одно из преступлений, совершенных по совокупности, является тяжким или особо тяжким преступлением, то окончательное наказание назначается путем частичного или полного сложения наказаний. При этом окончательное наказание в виде лишения свободы не может превышать более чем наполовину максимальный срок наказания в виде лишения свободы, предусмотренный за наиболее тяжкое из совершенных преступлений.`n4. При совокупности преступлений к основным видам наказаний могут быть присоединены дополнительные виды наказаний. Окончательное дополнительное наказание при частичном или полном сложении наказаний не может превышать максимального срока или размера, предусмотренного для данного вида наказания Общей частью настоящего Кодекса.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "36", title: "Назначение наказания по совокупности приговоров", description: "1. При назначении наказания по совокупности приговоров к наказанию, назначенному по последнему приговору суда, частично или полностью присоединяется неотбытая часть наказания по предыдущему приговору суда.`n2. Окончательное наказание по совокупности приговоров в случае, если оно менее строгое, чем лишение свободы, не может превышать максимального срока или размера, предусмотренного для данного вида наказания Общей частью настоящего Кодекса.`n3. Окончательное наказание по совокупности приговоров в виде лишения свободы не может превышать двадцати четырех (24) лет.`n4. Окончательное наказание по совокупности приговоров должно быть больше как наказания, назначенного за вновь совершенное преступление, так и неотбытой части наказания по предыдущему приговору суда. (Примечание: 1 год лишения свободы равен 5 минутам ареста.)", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    ; ========== Глава 5. Освобождение от уголовной ответственности. Помилование. Судимость ==========
    { article: "37", title: "Освобождение от уголовной ответственности в связи с истечением сроков давности", description: "1. Лицо освобождается от уголовной ответственности, если со дня совершения преступления истекли следующие сроки: а) три (3) дней после совершения преступления небольшой тяжести; б) десять (10) дней после совершения преступления средней тяжести; в) пятнадцать (15) дней после совершения тяжкого преступления; г) двадцать один (21) день после совершения особо тяжкого преступления.`n2. Сроки давности исчисляются со дня совершения преступления и до момента возбуждения уголовного дела. В случае совершения лицом нового преступления сроки давности по каждому преступлению исчисляются самостоятельно.`n3. Течение сроков давности приостанавливается, если лицо, совершившее преступление, уклоняется от следствия или суда. В этом случае течение сроков давности возобновляется с момента задержания указанного лица или явки его с повинной.`n4. К лицам, совершившим преступление, предусмотренного статьями 62, 63, 64, частью 2 статьи 65, частью 1 статьи 67, частью 1 и частью 2 статьи 68, 69, 74, 80, 82, 84, частью 2 статьи 99 настоящего Кодекса, а равно совершившим сопряженные с осуществлением террористической деятельности преступление, предусмотренное статьёй 79 настоящего Кодекса, сроки давности не применяются.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "38", title: "Освобождение или сокращение срока отбывания наказания под залог", description: "1. Адвокат, состоящий на государственной службе, вправе освободить или сократить срок лица, отбывающего наказание в учреждении исполнения наказаний под установленный настоящим Кодексом залог.`n2. Настоящим Кодексом устанавливаются следующие размеры залога при освобождении или сокращении срока отбывания наказания под залог: а) преступления небольшой тяжести — залог от десяти тысяч (10.000) рублей до двадцати пяти тысяч (25.000) рублей; б) преступления средней тяжести — залог от двадцати шести тысяч (26.000) рублей до пятидесяти тысяч (50.000) рублей; в) тяжкие преступления — залог от пятидесяти одной тысячи (51.000) рублей до семидесяти пяти тысяч (75.000) рублей; г) особо тяжкие преступления — залог от семидесяти шести тысяч (76.000) рублей до ста тысяч (100.000) рублей;`n3. В случае привлечения лица к уголовной ответственности по нескольким статьям залог суммируется за каждую статью согласно части 2 настоящей статьи.`n4. Стоимость освобождения под залог для каждой из статей Особенной части настоящего Кодекса устанавливается Министром юстиции Региональной Федерации.`n5. Освобождение адвокатом под залог допускается, если общий срок отбывания наказания лица составляет не более 6 лет.`n6. В случае если срок составляет более 6 лет и менее 10 лет, адвокат вправе сократить срок отбывания наказания, но не более чем наполовину.`n7. Не допускается освобождение или сокращение срока отбывания наказания лицу, направленному отбывать наказание по решению суда, в случае если в приговоре суда предусмотрен запрет на освобождение или сокращение срока под залог.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "39", title: "Помилование", description: "1. Помилование осуществляется Премьер-министром Региональной Федерации в отношении индивидуально определенного лица.`n2. Актом помилования лицо, осужденное за преступление, может быть освобождено от дальнейшего отбывания наказания либо назначенное ему наказание может быть сокращено или заменено более мягким видом наказания. С лица, отбывшего наказание, актом помилования может быть снята судимость.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "40", title: "Судимость", description: "1. Лицо, осужденное за совершение преступления, считается судимым со дня вступления обвинительного приговора суда в законную силу или с момента осуществления сотрудником правоохранительных органов ареста до момента погашения или снятия судимости, в случае совершения тяжкого и(или) особо тяжкого преступления. Судимость в соответствии с настоящим Кодексом учитывается при рецидиве преступлений, назначении наказания и влечет за собой иные правовые последствия в случаях и в порядке, которые установлены федеральными законами.`n2. Лицо, освобожденное от наказания, считается несудимым.`n3. Судимость погашается по истечению 14 календарных дней.`n4. Если осужденный в установленном законом порядке был досрочно освобожден от отбывания наказания или неотбытая часть наказания была заменена более мягким видом наказания, то срок погашения судимости исчисляется исходя из фактически отбытого срока наказания с момента освобождения от отбывания основного и дополнительного видов наказаний.`n5. Если осужденный после отбытия наказания вел себя безупречно, а также возместил вред, причиненный преступлением, то по его ходатайству суд может снять с него судимость до истечения срока погашения судимости.`n6. Погашение или снятие судимости аннулирует все правовые последствия, предусмотренные настоящим Кодексом, связанные с судимостью.`n7. Сотрудник правоохранительного органа, производящий арест лица, совершившего тяжкое и(или) особо тяжкое преступление, обязан сделать запись о судимости лица в личном деле. (Примечание: Статьи настоящего Кодекса, за которые предусмотрена запись о судимости имеют префикс (С) после номера статьи.)", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    ; ========== Глава 6. Судебный штраф ==========
    { article: "41", title: "Судебный штраф", description: "1. Судебный штраф есть денежное взыскание, назначаемое судом при освобождении лица от уголовной ответственности в случаях признания судом этой меры целесообразной для исправления лица, превенции дальнейших правонарушений и преступлений.`n2. В случае неуплаты судебного штрафа в установленный судом срок судебный штраф отменяется и лицо привлекается к уголовной ответственности по соответствующей статье Особенной части настоящего Кодекса.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "42", title: "Порядок определения размера судебного штрафа", description: "1. Размер судебного штрафа не может превышать половину максимального размера штрафа, предусмотренного соответствующей статьей Особенной части настоящего Кодекса. В случае, если штраф не предусмотрен соответствующей статьей Особенной части настоящего Кодекса, размер судебного штрафа не может быть более ста тысяч (100.000) рублей.`n2. Размер судебного штрафа определяется судом с учетом тяжести совершенного преступления и имущественного положения лица, освобождаемого от уголовной ответственности, и его семьи, а также с учетом возможности получения указанным лицом заработной платы или иного дохода.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    ; ========== Глава 7. Преступления против личности ==========
    { article: "43.1", title: "Убийство", description: "Убийство, то есть умышленное причинение смерти другому человеку, – наказывается лишением свободы на срок от 13 до 18 лет.", fine: 0, jail: 13, jail_max: 18, punishment: "лишение свободы на срок от 13 до 18 лет" },
    { article: "43.2", title: "Убийство при отягчающих обстоятельствах", description: "Убийство: а) двух или более лиц; б) совершенное с особой жестокостью; в) совершенное общеопасным способом; г) совершенное группой лиц, группой лиц по предварительному сговору или организованной группой; д) из корыстных побуждений или по найму, а равно сопряженное с разбоем, вымогательством или бандитизмом; е) по экстремистским мотивам; ж) с целью скрыть другое преступление или облегчить его совершение, – наказывается лишением свободы на срок от 19 до 24 лет.", fine: 0, jail: 19, jail_max: 24, punishment: "лишение свободы на срок от 19 до 24 лет" },
    { article: "44", title: "Причинение смерти по неосторожности", description: "Причинение смерти по неосторожности – наказывается лишением свободы на срок от 9 до 12 лет.", fine: 0, jail: 9, jail_max: 12, punishment: "лишение свободы на срок от 9 до 12 лет" },
    { article: "45", title: "Умышленное причинение тяжкого вреда здоровью", description: "Умышленное причинение тяжкого вреда здоровью – наказывается лишением свободы на срок от 6 до 9 лет.", fine: 0, jail: 6, jail_max: 9, punishment: "лишение свободы на срок от 6 до 9 лет" },
    { article: "46", title: "Умышленное причинение средней тяжести вреда здоровью", description: "Умышленное причинение вреда здоровью средней тяжести – наказывается лишением свободы на срок от 4 до 7 лет.", fine: 0, jail: 4, jail_max: 7, punishment: "лишение свободы на срок от 4 до 7 лет" },
    { article: "47", title: "Умышленное причинение легкого вреда здоровью", description: "Умышленное причинение лёгкого вреда здоровью с применением оружия или предметов, используемых в качестве оружия – наказывается штрафом в размере от 10 тысяч до 20 тысяч рублей, либо лишением свободы на срок от 2 до 5 лет.", fine: 20000, jail: 2, jail_max: 5, punishment: "штраф от 10 до 20 тыс. руб., либо лишение свободы от 2 до 5 лет" },
    { article: "48", title: "Побои", description: "Побои или иные насильственные действия, причинившие физическую боль, совершенные из хулиганских побуждений, а равно по экстремистским побуждениям – наказывается штрафом в размере от 5 тысяч до 15 тысяч рублей, либо лишением свободы на срок от 1 до 3 лет.", fine: 15000, jail: 1, jail_max: 3, punishment: "штраф от 5 до 15 тыс. руб., либо лишение свободы от 1 до 3 лет" },
    { article: "49.1", title: "Угроза убийством или причинением тяжкого вреда здоровью", description: "Угроза убийством или причинением тяжкого вреда здоровью – наказывается лишением свободы на срок от 1 до 3 лет.", fine: 0, jail: 1, jail_max: 3, punishment: "лишение свободы на срок от 1 до 3 лет" },
    { article: "49.2", title: "Угроза убийством при отягчающих обстоятельствах", description: "То же деяние, совершенное: а) по экстремистским побуждениям; б) в отношении представителя власти или его близких – наказывается лишением свободы на срок от 2 до 5 лет.", fine: 0, jail: 2, jail_max: 5, punishment: "лишение свободы на срок от 2 до 5 лет" },
    { article: "50", title: "Неоказание помощи больному", description: "Неоказание медицинской помощи больному без уважительных причин лицом, обязанным ее оказывать в соответствии с Законодательством Региональной Федерации, если это повлекло причинение средней тяжести вреда здоровью или тяжкого вреда здоровью больного – наказывается штрафом в размере от 10 тысяч до 15 тысяч рублей, либо лишением свободы на срок от 2 до 3 лет.", fine: 15000, jail: 2, jail_max: 3, punishment: "штраф от 10 до 15 тыс. руб., либо лишение свободы от 2 до 3 лет" },
    { article: "51", title: "Воспрепятствование оказанию медицинской помощи", description: "Воспрепятствование в какой бы то ни было форме законной деятельности медицинского работника по оказанию медицинской помощи, если это действие повлекло причинение смерти или тяжкого вреда здоровью пациента – наказывается штрафом в размере от 5 тысяч до 15 тысяч рублей, либо лишением свободы на срок от 3 до 5 лет.", fine: 15000, jail: 3, jail_max: 5, punishment: "штраф от 5 до 15 тыс. руб., либо лишение свободы от 3 до 5 лет" },
    { article: "52.1", title: "Похищение человека", description: "Похищение человека – наказывается лишением свободы на срок от 6 до 10 лет.", fine: 0, jail: 6, jail_max: 10, punishment: "лишение свободы на срок от 6 до 10 лет" },
    { article: "52.2", title: "Похищение человека при отягчающих обстоятельствах", description: "То же деяние, совершенное: а) группой лиц по предварительному сговору, организованной; б) с применением насилия, опасного для жизни или здоровья, либо с угрозой применения такого насилия; в) с применением оружия или предметов, используемых в качестве оружия; г) в отношении двух или более лиц; д) из корыстных побуждений или по найму – наказывается лишением свободы на срок от 8 до 12 лет.", fine: 0, jail: 8, jail_max: 12, punishment: "лишение свободы на срок от 8 до 12 лет" },
    { article: "52.3", title: "Похищение человека, повлекшее смерть", description: "То же деяние, повлекшее смерть потерпевшего или иные тяжкие последствия – наказывается лишением свободы на срок от 13 до 24 лет.", fine: 0, jail: 13, jail_max: 24, punishment: "лишение свободы на срок от 13 до 24 лет" },
    { article: "53.1", title: "Незаконное лишение свободы", description: "Незаконное лишение человека свободы, не связанное с его похищением – наказывается лишением свободы на срок от 4 до 8 лет.", fine: 0, jail: 4, jail_max: 8, punishment: "лишение свободы на срок от 4 до 8 лет" },
    { article: "53.2", title: "Незаконное лишение свободы при отягчающих обстоятельствах", description: "То же деяние, совершенное: а) группой лиц по предварительному сговору, организованной группой; б) с применением насилия, опасного для жизни или здоровья, либо с угрозой применения такого насилия; в) с применением оружия или предметов, используемых в качестве оружия; г) в отношении двух или более лиц; д) из корыстных побуждений или по найму – наказывается лишением свободы на срок от 8 до 10 лет.", fine: 0, jail: 8, jail_max: 10, punishment: "лишение свободы на срок от 8 до 10 лет" },
    { article: "53.3", title: "Незаконное лишение свободы, повлекшее смерть", description: "То же деяние, повлекшее смерть потерпевшего или иные тяжкие последствия – наказывается лишением свободы на срок от 13 до 24 лет.", fine: 0, jail: 13, jail_max: 24, punishment: "лишение свободы на срок от 13 до 24 лет" },
    { article: "54", title: "Изнасилование", description: "Изнасилование, то есть половое сношение с применением насилия или с угрозой его применения к потерпевшей или к другим лицам либо с использованием беспомощного состояния потерпевшей – наказывается лишением свободы на срок от 13 до 20 лет.", fine: 0, jail: 13, jail_max: 20, punishment: "лишение свободы на срок от 13 до 20 лет" },
    ; ========== Глава 8. Преступления в сфере экономики ==========
    { article: "55.1", title: "Кража", description: "Кража, то есть тайное хищение чужого имущества – наказывается штрафом в размере от 5 тысяч до 12 тысяч рублей, либо лишением свободы на срок от 1 до 3 лет.", fine: 12000, jail: 1, jail_max: 3, punishment: "штраф от 5 до 12 тыс. руб., либо лишение свободы от 1 до 3 лет" },
    { article: "55.2", title: "Кража при отягчающих обстоятельствах", description: "Кража, совершенная: а) группой лиц по предварительному сговору, организованной группой; б) с незаконным проникновением в жилище, помещение либо в иное хранилище; в) в крупном или особо крупном размере – наказывается лишением свободы на срок от 2 до 5 лет со штрафом в размере от 10 тысяч до 20 тысяч рублей.", fine: 20000, jail: 2, jail_max: 5, punishment: "лишение свободы от 2 до 5 лет со штрафом от 10 до 20 тыс. руб." },
    { article: "56.1", title: "Грабеж", description: "Грабеж, то есть открытое хищение чужого имущества – наказывается лишением свободы на срок от 2 до 4 лет.", fine: 0, jail: 2, jail_max: 4, punishment: "лишение свободы на срок от 2 до 4 лет" },
    { article: "56.2", title: "Грабеж при отягчающих обстоятельствах", description: "Грабёж, совершенный: а) группой лиц по предварительному сговору, организованной группой; б) с незаконным проникновением в жилище, помещение либо в иное хранилище; в) в крупном или особо крупном размере; г) с применением насилия не опасного для жизни, либо с угрозой применения такого насилия – наказывается лишением свободы на срок от 4 до 6 лет со штрафом в размере от 20 тысяч до 40 тысяч рублей.", fine: 40000, jail: 4, jail_max: 6, punishment: "лишение свободы от 4 до 6 лет со штрафом от 20 до 40 тыс. руб." },
    { article: "57.1", title: "Разбой", description: "Разбой, то есть нападение в целях хищения чужого имущества, совершенное с применением насилия, опасного для жизни или здоровья, либо с угрозой применения такого насилия – наказывается лишением свободы на срок от 3 до 7 лет со штрафом в размере от 15 тысяч до 25 тысяч рублей.", fine: 25000, jail: 3, jail_max: 7, punishment: "лишение свободы от 3 до 7 лет со штрафом от 15 до 25 тыс. руб." },
    { article: "57.2", title: "Разбой при отягчающих обстоятельствах", description: "Разбой, совершенный: а) группой лиц по предварительному сговору, организованной группой; б) с незаконным проникновением в жилище, помещение либо в иное хранилище; в) в крупном или особо крупном размере; г) с применением оружия или предметов, используемых в качестве оружия – наказывается лишением свободы на срок от 5 до 9 лет со штрафом в размере от 20 тысяч до 40 тысяч рублей.", fine: 40000, jail: 5, jail_max: 9, punishment: "лишение свободы от 5 до 9 лет со штрафом от 20 до 40 тыс. руб." },
    { article: "58.1", title: "Угон", description: "Неправомерное завладение автомобилем или иным транспортным средством без цели хищения (угон) – наказывается штрафом в размере от 5 тысяч до 15 тысяч рублей, либо лишением свободы на срок от 1 до 3 лет.", fine: 15000, jail: 1, jail_max: 3, punishment: "штраф от 5 до 15 тыс. руб., либо лишение свободы от 1 до 3 лет" },
    { article: "58.2", title: "Угон при отягчающих обстоятельствах", description: "То же деяние, совершенное: а) группой лиц по предварительному сговору, организованной группой; б) с применением насилия не опасного для жизни или здоровья, либо с угрозой применения такого насилия; в) с применением оружия или предметов, используемых в качестве оружия – наказывается лишением свободы на срок от 2 до 5 лет.", fine: 0, jail: 2, jail_max: 5, punishment: "лишение свободы от 2 до 5 лет" },
    { article: "58.3", title: "Угон с применением насилия, опасного для жизни", description: "То же деяние, совершенное с применением насилия опасного для жизни или здоровья, либо с угрозой применения такого насилия – наказывается лишением свободы на срок от 3 до 6 лет со штрафом в размере от 20 тысяч до 40 тысяч рублей.", fine: 40000, jail: 3, jail_max: 6, punishment: "лишение свободы от 3 до 6 лет со штрафом от 20 до 40 тыс. руб." },
    { article: "59.1", title: "Уничтожение или повреждение имущества", description: "Умышленные уничтожение или повреждение чужого имущества, если эти деяния повлекли причинение значительного ущерба – наказывается штрафом в размере от 5 тысяч до 20 тысяч рублей, либо лишением свободы на срок от 1 до 3 лет.", fine: 20000, jail: 1, jail_max: 3, punishment: "штраф от 5 до 20 тыс. руб., либо лишение свободы от 1 до 3 лет" },
    { article: "59.2", title: "Уничтожение или повреждение имущества в крупном размере по неосторожности", description: "Уничтожение или повреждение чужого имущества в крупном размере, совершенные путем неосторожного обращения с источниками повышенной опасности – наказывается штрафом в размере от 10 тысяч до 30 тысяч рублей.", fine: 30000, jail: 0, jail_max: 0, punishment: "штраф от 10 до 30 тыс. руб." },
    { article: "59.3", title: "Уничтожение или повреждение имущества из хулиганских побуждений", description: "Деяния, предусмотренные частью первой настоящей статьи, совершенные: а) из хулиганских побуждений; б) по экстремистским мотивам; в) общественно опасным способом – наказывается лишением свободы на срок от 2 до 5 лет со штрафом в размере от 10 тысяч до 40 тысяч рублей.", fine: 40000, jail: 2, jail_max: 5, punishment: "лишение свободы от 2 до 5 лет со штрафом от 10 до 40 тыс. руб." },
    { article: "60", title: "Незаконное предпринимательство", description: "Осуществление предпринимательской деятельности без регистрации или без лицензии – наказывается штрафом в размере от 20 тысяч до 60 тысяч рублей, либо лишением свободы на срок от 1 до 6 лет.", fine: 60000, jail: 1, jail_max: 6, punishment: "штраф от 20 до 60 тыс. руб., либо лишение свободы от 1 до 6 лет" },
    { article: "61.1", title: "Превышение полномочий частным адвокатом или работником частной охранной организации", description: "Совершение частным адвокатом или работником частной охранной организации, имеющим удостоверение частного охранника, действий, выходящих за пределы полномочий, установленных законодательством Региональной Федерации, регламентирующим осуществление частной охранной и детективной деятельности, и повлекших существенное нарушение прав и законных интересов граждан и (или) организаций либо охраняемых законом интересов общества или государства – наказывается штрафом в размере от 10 тысяч до 35 тысяч рублей, либо лишением свободы на срок от 2 до 5 лет.", fine: 35000, jail: 2, jail_max: 5, punishment: "штраф от 10 до 35 тыс. руб., либо лишение свободы от 2 до 5 лет" },
    { article: "61.2", title: "То же деяние с применением насилия или оружия", description: "То же деяние, совершенное с применением насилия или с угрозой его применения либо с использованием оружия или специальных средств и повлекшее тяжкие последствия – наказывается лишением свободы на срок от 4 до 6 лет.", fine: 0, jail: 4, jail_max: 6, punishment: "лишение свободы от 4 до 6 лет" },
    ; ========== Глава 9. Преступления против общественной безопасности и общественного порядка ==========
    { article: "62.1", title: "Террористический акт", description: "Совершение взрыва, поджога или иных действий, устрашающих население и создающих опасность гибели человека, причинения значительного имущественного ущерба либо наступления иных тяжких последствий, в целях дестабилизации деятельности органов власти либо воздействия на принятие ими решений, а также угроза совершения указанных действий в целях воздействия на принятие решений органами власти или международными организациями – наказывается лишением свободы на срок от 13 до 24 лет.", fine: 0, jail: 13, jail_max: 24, punishment: "лишение свободы на срок от 13 до 24 лет" },
    { article: "62.2", title: "Террористический акт, совершенный группой лиц", description: "Те же деяния, совершенные группой лиц, группой лиц по предварительному сговору или организованной группой – наказывается лишением свободы на срок от 18 до 24 лет.", fine: 0, jail: 18, jail_max: 24, punishment: "лишение свободы на срок от 18 до 24 лет" },
    { article: "63.1", title: "Организация террористического сообщества", description: "Создание террористического сообщества, то есть устойчивой группы лиц, заранее объединившихся в целях осуществления террористической деятельности – наказывается лишением свободы на срок от 13 до 24 лет.", fine: 0, jail: 13, jail_max: 24, punishment: "лишение свободы на срок от 13 до 24 лет" },
    { article: "63.2", title: "Участие в террористическом сообществе", description: "Участие в террористическом сообществе – наказывается лишением свободы на срок от 13 до 16 лет.", fine: 0, jail: 13, jail_max: 16, punishment: "лишение свободы на срок от 13 до 16 лет" },
    { article: "63.3", title: "Склонение к совершению террористической деятельности", description: "Склонение, вербовка или иное вовлечение лица в совершение террористической деятельности – наказывается лишением свободы на срок от 13 до 18 лет со штрафом в размере от 50 тысяч до 100 тысяч рублей.", fine: 100000, jail: 13, jail_max: 18, punishment: "лишение свободы на срок от 13 до 18 лет со штрафом от 50 до 100 тыс. руб." },
    { article: "64", title: "Публичные призывы к терроризму", description: "Публичные призывы к осуществлению террористической деятельности, публичное оправдание терроризма или пропаганда терроризма – наказывается лишением свободы на срок от 6 до 12 лет со штрафом в размере от 30 тысяч до 50 тысяч рублей.", fine: 50000, jail: 6, jail_max: 12, punishment: "лишение свободы на срок от 6 до 12 лет со штрафом от 30 до 50 тыс. руб." },
    { article: "65.1", title: "Захват заложника", description: "Захват или удержание лица в качестве заложника, совершенные в целях понуждения государства, организации или гражданина совершить какое-либо действие или воздержаться от совершения какого-либо действия как условия освобождения заложника – наказывается лишением свободы на срок от 8 до 12 лет.", fine: 0, jail: 8, jail_max: 12, punishment: "лишение свободы на срок от 8 до 12 лет" },
    { article: "65.2", title: "Захват заложника при отягчающих обстоятельствах", description: "То же деяние, совершенное: а) группой лиц, группой лиц по предварительному сговору, организованной группой; б) с применением насилия, опасного для жизни или здоровья, либо с угрозой применения такого насилия; в) с применением оружия или предметов, используемых в качестве оружия; г) в отношении двух или более лиц; д) из корыстных побуждений или по найму – наказывается лишением свободы на срок от 10 до 24 лет.", fine: 0, jail: 10, jail_max: 24, punishment: "лишение свободы на срок от 10 до 24 лет" },
    { article: "66.1", title: "Заведомо ложное сообщение об акте терроризма", description: "Заведомо ложное сообщение о готовящихся взрыве, поджоге или иных действиях, создающих опасность гибели людей, причинения значительного имущественного ущерба либо наступления иных общественно опасных последствий, совершенное из хулиганских побуждений – наказывается штрафом в размере от 20 тысяч до 50 тысяч рублей, либо лишением свободы на срок от 1 до 3 лет.", fine: 50000, jail: 1, jail_max: 3, punishment: "штраф от 20 до 50 тыс. руб., либо лишение свободы от 1 до 3 лет" },
    { article: "66.2", title: "То же деяние в целях дестабилизации", description: "То же деяние, совершенное: а) в целях дестабилизации деятельности органов власти; б) в отношении объектов социальной инфраструктуры – наказывается лишением свободы на срок от 2 до 6 лет со штрафом в размере от 20 тысяч до 40 тысяч рублей.", fine: 40000, jail: 2, jail_max: 6, punishment: "лишение свободы от 2 до 6 лет со штрафом от 20 до 40 тыс. руб." },
    { article: "67.1", title: "Бандитизм", description: "Создание устойчивой вооруженной группы (банды) в целях нападения на граждан или организации, а равно руководство такой группой (бандой) – наказывается лишением свободы на срок от 13 до 18 лет со штрафом в размере от 20 тысяч до 60 тысяч рублей.", fine: 60000, jail: 13, jail_max: 18, punishment: "лишение свободы на срок от 13 до 18 лет со штрафом от 20 до 60 тыс. руб." },
    { article: "67.2", title: "Участие в банде", description: "Участие в устойчивой вооруженной группе (банде) или в совершаемых ею нападениях – наказывается лишением свободы на срок от 5 до 8 лет со штрафом в размере от 5 тысяч до 30 тысяч рублей.", fine: 30000, jail: 5, jail_max: 8, punishment: "лишение свободы на срок от 5 до 8 лет со штрафом от 5 до 30 тыс. руб." },
    { article: "68.1", title: "Организация преступного сообщества", description: "Создание преступного сообщества (преступной организации) в целях совершения тяжких или особо тяжких преступлений либо руководство преступным сообществом (преступной организацией) или входящими в него (нее) структурными подразделениями, а равно координация действий организованных групп, разработка планов и создание условий для совершения преступлений организованными группами, раздел сфер преступного влияния и (или) преступных доходов между такими группами – наказывается лишением свободы на срок от 13 до 24 лет со штрафом в размере от 20 тысяч до 100 тысяч рублей.", fine: 100000, jail: 13, jail_max: 24, punishment: "лишение свободы на срок от 13 до 24 лет со штрафом от 20 до 100 тыс. руб." },
    { article: "68.2", title: "Участие в собрании организаторов преступных сообществ", description: "Участие в собрании организаторов, руководителей (лидеров) или иных представителей преступных сообществ (преступных организаций) и (или) организованных групп в целях совершения хотя бы одного из преступлений, предусмотренных частью первой настоящей статьи – наказываются лишением свободы на срок от 13 до 18 лет со штрафом в размере от 20 тысяч до 70 тысяч рублей.", fine: 70000, jail: 13, jail_max: 18, punishment: "лишение свободы на срок от 13 до 18 лет со штрафом от 20 до 70 тыс. руб." },
    { article: "68.3", title: "Участие в преступном сообществе", description: "Участие в преступном сообществе (преступной организации) – наказывается лишением свободы на срок от 4 до 7 лет со штрафом в размере от 5 тысяч до 15 тысяч рублей.", fine: 15000, jail: 4, jail_max: 7, punishment: "лишение свободы на срок от 4 до 7 лет со штрафом от 5 до 15 тыс. руб." },
    { article: "69", title: "Занятие высшего положения в преступной иерархии", description: "Занятие высшего положения в преступной иерархии – наказывается лишением свободы на срок от 16 до 24 лет со штрафом в размере от 50 тысяч до 100 тысяч рублей.", fine: 100000, jail: 16, jail_max: 24, punishment: "лишение свободы на срок от 16 до 24 лет со штрафом от 50 до 100 тыс. руб." },
    { article: "70.1", title: "Организация массовых беспорядков", description: "Организация массовых беспорядков, сопровождавшихся насилием, погромами, поджогами, уничтожением имущества, применением оружия, взрывных устройств, взрывчатых, отравляющих либо иных веществ и предметов, представляющих опасность для окружающих, а также оказанием вооруженного сопротивления представителю власти, а равно подготовка лица для организации таких массовых беспорядков или участия в них – наказывается лишением свободы на срок от 13 до 20 лет со штрафом в размере от 10 тысяч до 40 тысяч рублей.", fine: 40000, jail: 13, jail_max: 20, punishment: "лишение свободы на срок от 13 до 20 лет со штрафом от 10 до 40 тыс. руб." },
    { article: "70.2", title: "Склонение к участию в массовых беспорядках", description: "Склонение, вербовка, вовлечение лица в совершение действий, предусмотренных частью первой настоящей статьи – наказывается лишением свободы на срок от 10 до 15 лет.", fine: 0, jail: 10, jail_max: 15, punishment: "лишение свободы на срок от 10 до 15 лет" },
    { article: "70.3", title: "Участие в массовых беспорядках", description: "Участие в массовых беспорядках – наказывается лишением свободы на срок от 3 до 8 лет.", fine: 0, jail: 3, jail_max: 8, punishment: "лишение свободы на срок от 3 до 8 лет" },
    { article: "71.1", title: "Хулиганство", description: "Хулиганство, то есть грубое нарушение общественного порядка, выражающее явное неуважение к обществу, совершенное: а) применением насилия к гражданам либо угрозой его применения; б) по экстремистским мотивам – наказывается штрафом в размере от 5 тысяч до 15 тысяч рублей, либо лишением свободы на срок от 2 до 3 лет.", fine: 15000, jail: 2, jail_max: 3, punishment: "штраф от 5 до 15 тыс. руб., либо лишение свободы от 2 до 3 лет" },
    { article: "71.2", title: "Хулиганство с применением оружия или группой лиц", description: "То же деяние, совершенное с применением оружия или предметов, используемых в качестве оружия, либо группой лиц, группой лиц по предварительному сговору или организованной группой либо связанное с сопротивлением представителю власти, исполняющему обязанности по охране общественного порядка или пресекающему нарушение общественного порядка – наказывается лишением свободы на срок от 2 до 6 лет.", fine: 0, jail: 2, jail_max: 6, punishment: "лишение свободы на срок от 2 до 6 лет" },
    { article: "72", title: "Незаконное проникновение на закрытый или охраняемый объект", description: "Незаконное проникновение на закрытый или охраняемый государственный объект, сооружение на коммуникациях, к специальному грузу – наказывается штрафом в размере от 5 тысяч до 15 тысяч рублей, либо лишением свободы на срок от 2 до 4 лет.", fine: 15000, jail: 2, jail_max: 4, punishment: "штраф от 5 до 15 тыс. руб., либо лишение свободы от 2 до 4 лет" },
    { article: "73.1", title: "Незаконные приобретение, хранение, ношение оружия", description: "Незаконные приобретение, передача, хранение, перевозка, пересылка, ношение, а равно использование и изготовление огнестрельного оружия, его основных частей и боеприпасов к нему – наказывается лишением свободы на срок от 2 до 4 лет.", fine: 0, jail: 2, jail_max: 4, punishment: "лишение свободы на срок от 2 до 4 лет" },
    { article: "73.2", title: "Незаконный сбыт оружия", description: "Незаконный сбыт огнестрельного оружия, его основных частей, боеприпасов к нему – наказывается лишением свободы на срок от 3 до 5 лет со штрафом в размере от 10 тысяч до 30 тысяч рублей.", fine: 30000, jail: 3, jail_max: 5, punishment: "лишение свободы на срок от 3 до 5 лет со штрафом от 10 до 30 тыс. руб." },
    { article: "73.3", title: "Незаконные действия с оружием, совершенные группой лиц", description: "Деяния, предусмотренные частью первой настоящей статьи, совершенные: а) группой лиц, группой лиц по предварительному сговору, организованной группой; б) лицом с использованием своего служебного положения – наказывается лишением свободы на срок от 2 до 5 лет со штрафом в размере от 10 тысяч до 30 тысяч рублей.", fine: 30000, jail: 2, jail_max: 5, punishment: "лишение свободы на срок от 2 до 5 лет со штрафом от 10 до 30 тыс. руб." },
    { article: "73.4", title: "Незаконный сбыт оружия, совершенный группой лиц", description: "Деяния, предусмотренные частью второй настоящей статьи, совершенные: а) группой лиц, группой лиц по предварительному сговору, организованной группой; б) лицом с использованием своего служебного положения – наказывается лишением свободы на срок от 5 до 6 лет со штрафом в размере от 20 тысяч до 45 тысяч рублей.", fine: 45000, jail: 5, jail_max: 6, punishment: "лишение свободы на срок от 5 до 6 лет со штрафом от 20 до 45 тыс. руб." },
    { article: "74", title: "Пиратство", description: "Нападение на морское или речное судно в целях завладения чужим имуществом, совершенное с применением насилия либо с угрозой его применения – наказывается лишением свободы на срок от 7 до 15 лет.", fine: 0, jail: 7, jail_max: 15, punishment: "лишение свободы на срок от 7 до 15 лет" },
    ; ========== Глава 10. Преступления против конституционных прав и свобод человека и гражданина ==========
    { article: "75.1", title: "Воспрепятствование осуществлению избирательных прав", description: "Воспрепятствование свободному осуществлению гражданином своих избирательных прав или права на участие в референдуме, нарушение тайны голосования, а также воспрепятствование работе, связанной с избирательным процессом или референдумом – наказывается штрафом в размере от 15 тысяч до 20 тысяч рублей, либо лишением свободы на срок от 1 до 3 лет.", fine: 20000, jail: 1, jail_max: 3, punishment: "штраф от 15 до 20 тыс. руб., либо лишение свободы от 1 до 3 лет" },
    { article: "75.2", title: "Воспрепятствование избирательным правам с подкупом или насилием", description: "Те же деяния: а) соединенные с подкупом, обманом, принуждением, применением насилия либо с угрозой его применения; б) совершенные лицом с использованием своего служебного положения; в) совершенные группой лиц по предварительному сговору или организованной группой – наказывается лишением свободы на срок от 3 до 5 лет со штрафом в размере от 15 тысяч до 30 тысяч рублей.", fine: 30000, jail: 3, jail_max: 5, punishment: "лишение свободы от 3 до 5 лет со штрафом от 15 до 30 тыс. руб." },
    { article: "76", title: "Нарушение неприкосновенности жилища", description: "Незаконное проникновение в жилище, совершенное против воли проживающего в нем лица – наказывается штрафом в размере от 10 тысяч до 25 тысяч рублей, либо лишением свободы на срок от 2 до 3 лет.", fine: 25000, jail: 2, jail_max: 3, punishment: "штраф от 10 до 25 тыс. руб., либо лишение свободы от 2 до 3 лет" },
    { article: "77", title: "Воспрепятствование проведению собрания, митинга, демонстрации", description: "Незаконное воспрепятствование проведению собрания, митинга, демонстрации, шествия, пикетирования или участию в них либо принуждение к участию в них, если эти деяния совершены должностным лицом с использованием своего служебного положения либо с применением насилия или с угрозой его применения – наказывается штрафом в размере от 10 тысяч до 30 тысяч рублей.", fine: 30000, jail: 0, jail_max: 0, punishment: "штраф от 10 до 30 тыс. руб." },
    ; ========== Глава 11. Преступления против основ конституционного строя и безопасности государства ==========
    { article: "78", title: "Государственная измена", description: "Государственная измена, то есть совершенные гражданином Региональной Федерации шпионаж, выдача сведений, составляющих государственную тайну, доверенную лицу или ставшую известной ему по службе, работе, учебе или в иных случаях, предусмотренных законодательством Региональной Федерации, либо оказание финансовой, материально-технической, консультационной или иной помощи, направленной против безопасности Региональной Федерации – наказывается лишением свободы на срок от 18 до 24 лет со штрафом в размере до 100 тысяч рублей.", fine: 100000, jail: 18, jail_max: 24, punishment: "лишение свободы на срок от 18 до 24 лет со штрафом до 100 тыс. руб." },
    { article: "79", title: "Посягательство на жизнь государственного или общественного деятеля", description: "Посягательство на жизнь государственного или общественного деятеля, совершенное в целях прекращения его государственной или иной политической деятельности либо из мести за такую деятельность – наказывается лишением свободы на срок от 10 до 16 лет.", fine: 0, jail: 10, jail_max: 16, punishment: "лишение свободы на срок от 10 до 16 лет" },
    { article: "80.1", title: "Вооруженный мятеж", description: "Организация вооруженного мятежа или руководство им в целях свержения или насильственного изменения конституционного строя Региональной Федерации либо нарушения территориальной целостности Региональной Федерации – наказывается лишением свободы на срок от 18 до 24 лет.", fine: 0, jail: 18, jail_max: 24, punishment: "лишение свободы на срок от 18 до 24 лет" },
    { article: "80.2", title: "Участие в вооруженном мятеже", description: "Участие в вооруженном мятеже в целях, указанных в части первой настоящей статьи – наказывается лишением свободы на срок от 13 до 18 лет.", fine: 0, jail: 13, jail_max: 18, punishment: "лишение свободы на срок от 13 до 18 лет" },
    { article: "81", title: "Публичные призывы к экстремистской деятельности", description: "Публичные призывы к осуществлению экстремистской деятельности или деятельности, направленной против безопасности Региональной Федерации, либо к воспрепятствованию исполнения органами власти и их должностными лицами своих полномочий по обеспечению безопасности Региональной Федерации – наказывается штрафом в размере до 70 тысяч рублей, либо лишением свободы на срок от 2 до 6 лет.", fine: 70000, jail: 2, jail_max: 6, punishment: "штраф до 70 тыс. руб., либо лишение свободы от 2 до 6 лет" },
    { article: "82.1", title: "Диверсия", description: "Совершение взрыва, поджога или иных действий, направленных на разрушение или повреждение предприятий, сооружений, объектов транспортной инфраструктуры и транспортных средств, средств связи, объектов жизнеобеспечения населения либо на нанесение вреда здоровью людей и (или) компонентам природной среды, если эти действия совершены в целях подрыва экономической безопасности и (или) обороноспособности Региональной Федерации – наказывается лишением свободы на срок от 10 до 16 лет.", fine: 0, jail: 10, jail_max: 16, punishment: "лишение свободы на срок от 10 до 16 лет" },
    { article: "82.2", title: "Диверсия, совершенная группой лиц", description: "Те же деяния, совершенные группой лиц по предварительному сговору или организованной группой – наказывается лишением свободы на срок от 13 до 18 лет.", fine: 0, jail: 13, jail_max: 18, punishment: "лишение свободы на срок от 13 до 18 лет" },
    { article: "83.1", title: "Возбуждение ненависти либо вражды", description: "Действия, направленные на возбуждение ненависти либо вражды, а также на унижение достоинства человека либо группы лиц по признакам пола, расы, национальности, языка, происхождения, отношения к религии, а равно принадлежности к какой-либо социальной группе, совершенные публично, в том числе с использованием средств массовой информации либо информационно-телекоммуникационных сетей, лицом, подвергнутым административному наказанию за аналогичное деяние – наказывается штрафом в размере до 30 тысяч рублей, либо лишением свободы на срок от 3 до 5 лет.", fine: 30000, jail: 3, jail_max: 5, punishment: "штраф до 30 тыс. руб., либо лишение свободы от 3 до 5 лет" },
    { article: "83.2", title: "То же деяние с применением насилия или группой лиц", description: "Действия, направленные на возбуждение ненависти либо вражды, а также на унижение достоинства человека либо группы лиц по признакам пола, расы, национальности, языка, происхождения, отношения к религии, а равно принадлежности к какой-либо социальной группе, совершенные публично, в том числе с использованием средств массовой информации либо информационно-телекоммуникационных сетей: а) с применением насилия или угрозой его применения; б) группой лиц, группой лиц по предварительному сговору или организованной группой – наказывается штрафом в размере до 50 тысяч рублей, либо лишением свободы на срок от 4 до 6 лет.", fine: 50000, jail: 4, jail_max: 6, punishment: "штраф до 50 тыс. руб., либо лишение свободы от 4 до 6 лет" },
    { article: "84.1", title: "Организация экстремистского сообщества", description: "Создание экстремистского сообщества, то есть организованной группы лиц для подготовки или совершения преступлений экстремистской направленности, а равно руководство таким экстремистским сообществом или его частью – наказывается штрафом в размере до 100 тысяч рублей, либо лишением свободы на срок от 14 до 20 лет.", fine: 100000, jail: 14, jail_max: 20, punishment: "штраф до 100 тыс. руб., либо лишение свободы на срок от 14 до 20 лет" },
    { article: "84.2", title: "Участие в экстремистском сообществе", description: "Участие в экстремистском сообществе – наказывается штрафом в размере до 40 тысяч рублей, либо лишением свободы на срок от 6 до 9 лет.", fine: 40000, jail: 6, jail_max: 9, punishment: "штраф до 40 тыс. руб., либо лишение свободы на срок от 6 до 9 лет" },
    { article: "85", title: "Разглашение государственной тайны", description: "Разглашение сведений, составляющих государственную тайну, лицом, которому она была доверена или стала известна по службе, работе – наказывается лишением свободы на срок от 13 до 17 лет.", fine: 0, jail: 13, jail_max: 17, punishment: "лишение свободы на срок от 13 до 17 лет" },
    { article: "86", title: "Незаконное получение сведений, составляющих государственную тайну", description: "Получение сведений, составляющих государственную тайну, путем похищения, обмана, шантажа, принуждения, угрозы применения насилия либо иным незаконным способом – наказывается лишением свободы на срок от 13 до 15 лет.", fine: 0, jail: 13, jail_max: 15, punishment: "лишение свободы на срок от 13 до 15 лет" },
    ; ========== Глава 12. Преступления против государственной власти и интересов государственной службы ==========
    { article: "87.1", title: "Злоупотребление должностными полномочиями", description: "Использование должностным лицом своих служебных полномочий вопреки интересам службы, если это деяние совершено из корыстной или иной личной заинтересованности и повлекло существенное нарушение прав и законных интересов граждан или организаций либо охраняемых законом интересов общества или государства – наказывается штрафом в размере до 20 тысяч рублей, либо лишением свободы на срок до 8 лет.", fine: 20000, jail: 0, jail_max: 8, punishment: "штраф до 20 тыс. руб., либо лишение свободы до 8 лет" },
    { article: "87.2", title: "Злоупотребление должностными полномочиями, повлекшее тяжкие последствия", description: "То же деяние, повлекшее тяжкие последствия – наказывается лишением свободы на срок до 13 лет.", fine: 0, jail: 0, jail_max: 13, punishment: "лишение свободы до 13 лет" },
    { article: "88.1", title: "Превышение должностных полномочий", description: "Совершение должностным лицом действий, явно выходящих за пределы его полномочий и повлекших существенное нарушение прав и законных интересов граждан или организаций либо охраняемых законом интересов общества или государства – наказывается штрафом в размере до 30 тысяч рублей, либо лишением свободы на срок до 10 лет.", fine: 30000, jail: 0, jail_max: 10, punishment: "штраф до 30 тыс. руб., либо лишение свободы до 10 лет" },
    { article: "88.2", title: "Превышение должностных полномочий с применением насилия", description: "Те же деяния, если они совершены: а) с применением насилия или с угрозой его применения; б) с применением оружия или специальных средств; в) с причинением тяжких последствий; г) группой лиц, группой лиц по предварительному сговору или организованной группой; д) из корыстной или иной личной заинтересованности – наказывается лишением свободы на срок от 10 до 16 лет.", fine: 0, jail: 10, jail_max: 16, punishment: "лишение свободы на срок от 10 до 16 лет" },
    { article: "88.3", title: "Превышение должностных полномочий с применением пытки", description: "Деяния, предусмотренные частями первой или второй настоящей статьи, совершенные с применением пытки – наказывается лишением свободы на срок от 12 до 18 лет.", fine: 0, jail: 12, jail_max: 18, punishment: "лишение свободы на срок от 12 до 18 лет" },
    { article: "89", title: "Присвоение полномочий должностного лица", description: "Присвоение лицом, не занимающим должность, полномочий должностного лица и совершение им в связи с этим действий, которые повлекли существенное нарушение прав и законных интересов граждан или организаций – наказывается штрафом в размере до 30 тысяч рублей, либо лишением свободы на срок до 10 лет.", fine: 30000, jail: 0, jail_max: 10, punishment: "штраф до 30 тыс. руб., либо лишение свободы до 10 лет" },
    { article: "90.1", title: "Неисполнение должностным лицом приказа", description: "Умышленное неисполнение должностным лицом приказа начальника, отданного в установленном порядке и не противоречащего закону, причинившее существенный вред правам и законным интересам граждан или организаций либо охраняемым законом интересам общества или государства – наказывается лишением свободы на срок до 9 лет.", fine: 0, jail: 0, jail_max: 9, punishment: "лишение свободы до 9 лет" },
    { article: "90.2", title: "Неисполнение приказа группой лиц", description: "То же деяние, совершенное группой лиц, группой лиц по предварительному сговору или организованной группой, а равно повлекшее тяжкие последствия – наказывается лишением свободы на срок до 14 лет.", fine: 0, jail: 0, jail_max: 14, punishment: "лишение свободы до 14 лет" },
    { article: "91", title: "Отказ в предоставлении информации Федеральному Собранию", description: "Неправомерный отказ в предоставлении или уклонение от предоставления информации (документов, материалов), а также предоставление заведомо неполной либо ложной информации Федеральному Собрания Региональной Федерации, если эти деяния совершены должностным лицом, обязанным предоставлять такую информацию – наказывается лишением свободы на срок до 6 лет.", fine: 0, jail: 0, jail_max: 6, punishment: "лишение свободы до 6 лет" },
    { article: "92.1", title: "Получение взятки", description: "Получение должностным лицом лично или через посредника взятки в виде денег, имущества, либо в виде незаконных оказания ему услуг имущественного характера, предоставления иных имущественных прав (в том числе когда взятка по указанию должностного лица передается иному лицу) за совершение действий (бездействие) в пользу взяткодателя или представляемых им лиц, если указанные действия (бездействие) входят в служебные полномочия должностного лица либо если оно в силу должностного положения может способствовать указанным действиям (бездействию), а равно за общее покровительство или попустительство по службе – наказывается штрафом в размере до 50 тысяч рублей, либо лишением свободы на срок до 8 лет.", fine: 50000, jail: 0, jail_max: 8, punishment: "штраф до 50 тыс. руб., либо лишение свободы до 8 лет" },
    { article: "92.2", title: "Получение взятки за незаконные действия", description: "Получение должностным лицом взятки за незаконные действия (бездействие) – наказывается штрафом в размере до 70 тысяч рублей, либо лишением свободы на срок до 12 лет.", fine: 70000, jail: 0, jail_max: 12, punishment: "штраф до 70 тыс. руб., либо лишение свободы до 12 лет" },
    { article: "93.1", title: "Дача взятки", description: "Дача взятки должностному лицу лично или через посредника (в том числе когда взятка по указанию должностного лица передается иному лицу) – наказывается штрафом в размере до 30 тысяч рублей, либо лишением свободы на срок до 7 лет.", fine: 30000, jail: 0, jail_max: 7, punishment: "штраф до 30 тыс. руб., либо лишение свободы до 7 лет" },
    { article: "93.2", title: "Дача взятки за заведомо незаконные действия", description: "Дача взятки должностному лицу лично или через посредника (в том числе когда взятка по указанию должностного лица передается иному физическому или юридическому лицу) за совершение заведомо незаконных действий (бездействие) – наказывается штрафом в размере до 40 тысяч рублей, либо лишением свободы на срок до 10 лет.", fine: 40000, jail: 0, jail_max: 10, punishment: "штраф до 40 тыс. руб., либо лишение свободы до 10 лет" },
    { article: "94", title: "Служебный подлог", description: "Служебный подлог, то есть внесение должностным лицом в официальные документы заведомо ложных сведений, а равно внесение в указанные документы исправлений, искажающих их действительное содержание, если эти деяния совершены из корыстной или иной личной заинтересованности – наказывается штрафом в размере от 20 тысяч до 35 тысяч рублей, либо лишением свободы на срок до 6 лет.", fine: 35000, jail: 0, jail_max: 6, punishment: "штраф от 20 до 35 тыс. руб., либо лишение свободы до 6 лет" },
    { article: "95", title: "Халатность", description: "Халатность, то есть неисполнение или ненадлежащее исполнение должностным лицом своих обязанностей вследствие недобросовестного или небрежного отношения к службе либо обязанностей по должности, если это повлекло причинение ущерба или существенное нарушение прав и законных интересов граждан или организаций либо охраняемых законом интересов общества или государства – наказывается штрафом в размере до 15 тысяч рублей, либо лишением свободы на срок от 1 до 5 лет.", fine: 15000, jail: 1, jail_max: 5, punishment: "штраф до 15 тыс. руб., либо лишение свободы от 1 до 5 лет" },
    ; ========== Глава 13. Преступления против правосудия ==========
    { article: "96.1", title: "Воспрепятствование осуществлению правосудия", description: "Вмешательство в какой бы то ни было форме в деятельность суда в целях воспрепятствования осуществлению правосудия – наказывается штрафом в размере от 10 тысяч до 30 тысяч рублей, либо лишением свободы на срок до 9 лет.", fine: 30000, jail: 0, jail_max: 9, punishment: "штраф от 10 до 30 тыс. руб., либо лишение свободы до 9 лет" },
    { article: "96.2", title: "Воспрепятствование производству предварительного расследования", description: "Вмешательство в какой бы то ни было форме в деятельность прокурора, следователя или лица, производящего дознание, в целях воспрепятствования всестороннему, полному и объективному расследованию дела – наказывается штрафом в размере от 5 тысяч до 25 тысяч рублей, либо лишением свободы на срок до 7 лет.", fine: 25000, jail: 0, jail_max: 7, punishment: "штраф от 5 до 25 тыс. руб., либо лишение свободы до 7 лет" },
    { article: "97", title: "Посягательство на жизнь лица, осуществляющего правосудие или предварительное расследование", description: "Посягательство на жизнь судьи, прокурора, следователя, лица, производящего дознание, защитника, эксперта, специалиста, сотрудника органов принудительного исполнения Региональной Федерации, а равно их близких в связи с рассмотрением дел или материалов в суде, производством предварительного расследования либо исполнением приговора, решения суда или иного судебного акта, совершенное в целях воспрепятствования законной деятельности указанных лиц либо из мести за такую деятельность – наказывается лишением свободы на срок до 12 лет.", fine: 0, jail: 0, jail_max: 12, punishment: "лишение свободы до 12 лет" },
    { article: "98.1", title: "Неуважение к суду (оскорбление участников)", description: "Неуважение к суду, выразившееся в оскорблении участников судебного разбирательства – наказывается штрафом в размере от 5 тысяч до 20 тысяч рублей.", fine: 20000, jail: 0, jail_max: 0, punishment: "штраф от 5 до 20 тыс. руб." },
    { article: "98.2", title: "Неуважение к суду (оскорбление судьи)", description: "То же деяние, выразившееся в оскорблении судьи – наказывается штрафом в размере от 15 тысяч до 30 тысяч рублей, либо лишением свободы на срок до 5 лет.", fine: 30000, jail: 0, jail_max: 5, punishment: "штраф от 15 до 30 тыс. руб., либо лишение свободы до 5 лет" },
    { article: "99.1", title: "Привлечение заведомо невиновного к уголовной ответственности", description: "Привлечение заведомо невиновного к уголовной ответственности – наказывается лишением свободы на срок от 8 до 10 лет.", fine: 0, jail: 8, jail_max: 10, punishment: "лишение свободы на срок от 8 до 10 лет" },
    { article: "99.2", title: "Привлечение заведомо невиновного к ответственности за тяжкое преступление", description: "То же деяние, соединенное с обвинением лица в совершении тяжкого или особо тяжкого преступления либо повлекшее причинение крупного ущерба или иные тяжкие последствия – наказывается лишением свободы на срок от 13 до 15 лет.", fine: 0, jail: 13, jail_max: 15, punishment: "лишение свободы на срок от 13 до 15 лет" },
    { article: "100", title: "Незаконное освобождение от уголовной ответственности", description: "Незаконное освобождение от уголовной ответственности лица, подозреваемого или обвиняемого в совершении преступления – наказывается лишением свободы на срок от 6 до 12 лет.", fine: 0, jail: 6, jail_max: 12, punishment: "лишение свободы на срок от 6 до 12 лет" },
    { article: "101.1", title: "Незаконное задержание", description: "Заведомо незаконное задержание – наказывается лишением свободы на срок от 4 до 8 лет.", fine: 0, jail: 4, jail_max: 8, punishment: "лишение свободы на срок от 4 до 8 лет" },
    { article: "101.2", title: "Незаконные заключение под стражу или содержание под стражей", description: "Заведомо незаконные заключение под стражу или содержание под стражей – наказывается лишением свободы на срок от 6 до 12 лет.", fine: 0, jail: 6, jail_max: 12, punishment: "лишение свободы на срок от 6 до 12 лет" },
    { article: "102", title: "Вынесение заведомо неправосудных приговора, решения или иного судебного акта", description: "Вынесение судьей (судьями) заведомо неправосудных приговора, решения или иного судебного акта – наказывается штрафом в размере от 10 тысяч до 25 тысяч рублей, либо лишением свободы на срок от 5 до 13 лет.", fine: 25000, jail: 5, jail_max: 13, punishment: "штраф от 10 до 25 тыс. руб., либо лишение свободы от 5 до 13 лет" },
    { article: "103", title: "Заведомо ложный донос", description: "Заведомо ложный донос о совершении преступления – наказывается штрафом в размере от 5 тысяч до 15 тысяч рублей, либо лишением свободы на срок от 3 до 6 лет.", fine: 15000, jail: 3, jail_max: 6, punishment: "штраф от 5 до 15 тыс. руб., либо лишение свободы от 3 до 6 лет" },
    { article: "104", title: "Заведомо ложные показание, заключение специалиста", description: "Заведомо ложные показание свидетеля, потерпевшего либо заключение, показание специалиста – наказывается штрафом в размере от 20 тысяч до 35 тысяч рублей, либо лишением свободы на срок от 2 до 6 лет.", fine: 35000, jail: 2, jail_max: 6, punishment: "штраф от 20 до 35 тыс. руб., либо лишение свободы от 2 до 6 лет" },
    { article: "105", title: "Разглашение данных предварительного расследования", description: "Разглашение данных предварительного расследования лицом, предупрежденным в установленном законом порядке о недопустимости их разглашения, если оно совершено без согласия следователя или лица, производящего дознание – наказывается штрафом в размере от 20 тысяч до 45 тысяч рублей, либо лишением свободы на срок от 4 до 6 лет.", fine: 45000, jail: 4, jail_max: 6, punishment: "штраф от 20 до 45 тыс. руб., либо лишение свободы от 4 до 6 лет" },
    { article: "106.1", title: "Побег из места лишения свободы, из-под ареста или из-под стражи", description: "Побег из места лишения свободы, из-под ареста или из-под стражи, совершенный лицом, отбывающим наказание или находящимся в предварительном заключении – наказывается лишением свободы на срок от 5 до 7 лет.", fine: 0, jail: 5, jail_max: 7, punishment: "лишение свободы на срок от 5 до 7 лет" },
    { article: "106.2", title: "Побег группой лиц", description: "То же деяние, совершенное группой лиц по предварительному сговору или организованной группой – наказывается лишением свободы на срок от 6 до 9 лет.", fine: 0, jail: 6, jail_max: 9, punishment: "лишение свободы на срок от 6 до 9 лет" },
    { article: "106.3", title: "Побег с применением насилия", description: "Деяния, предусмотренные частями первой или второй настоящей статьи, совершенные с применением насилия, опасного для жизни или здоровья, либо с угрозой применения такого насилия, а равно с применением оружия или предметов, используемых в качестве оружия – наказывается лишением свободы на срок от 8 до 12 лет.", fine: 0, jail: 8, jail_max: 12, punishment: "лишение свободы на срок от 8 до 12 лет" },
    { article: "107", title: "Неисполнение приговора суда, решения суда или иного судебного акта", description: "Злостное неисполнение вступивших в законную силу приговора суда, решения суда или иного судебного акта, а равно воспрепятствование их исполнению – наказывается штрафом в размере от 15 тысяч до 30 тысяч рублей, либо лишением свободы на срок от 4 до 10 лет.", fine: 30000, jail: 4, jail_max: 10, punishment: "штраф от 15 до 30 тыс. руб., либо лишение свободы от 4 до 10 лет" },
    ; ========== Глава 14. Преступления против порядка управления ==========
    { article: "108", title: "Посягательство на жизнь сотрудника правоохранительного органа", description: "Посягательство на жизнь сотрудника правоохранительного органа, военнослужащего, а равно их близких в целях воспрепятствования законной деятельности указанных лиц – наказывается лишением свободы на срок от 6 до 12 лет.", fine: 0, jail: 6, jail_max: 12, punishment: "лишение свободы на срок от 6 до 12 лет" },
    { article: "109.1", title: "Применение насилия в отношении представителя власти", description: "Применение насилия, не опасного для жизни или здоровья, либо угроза применения такового в отношении представителя власти или его близких – наказывается штрафом в размере от 10 тысяч до 25 тысяч рублей, либо лишением свободы на срок от 3 до 7 лет.", fine: 25000, jail: 3, jail_max: 7, punishment: "штраф от 10 до 25 тыс. руб., либо лишение свободы от 3 до 7 лет" },
    { article: "109.2", title: "Применение насилия, опасного для жизни или здоровья", description: "Применение насилия, опасного для жизни или здоровья, в отношении лиц, указанных в части первой настоящей статьи – наказывается лишением свободы на срок от 5 до 10 лет.", fine: 0, jail: 5, jail_max: 10, punishment: "лишение свободы на срок от 5 до 10 лет" },
    { article: "110", title: "Оскорбление представителя власти", description: "Публичное оскорбление представителя власти при исполнении им своих должностных обязанностей или в связи с их исполнением – наказывается штрафом в размере от 5 тысяч до 15 тысяч рублей, либо лишением свободы на срок от 1 до 3 лет.", fine: 15000, jail: 1, jail_max: 3, punishment: "штраф от 5 до 15 тыс. руб., либо лишение свободы от 1 до 3 лет" },
    { article: "111", title: "Подделка, изготовление или оборот поддельных документов, государственных наград, штампов, печатей или бланков", description: "Подделка, изготовление или оборот поддельных документов, наделяющих правами или освобождающих от обязанностей, государственных наград, штампов, печатей, бланков, жетонов – наказывается лишением свободы на срок от 3 до 6 лет.", fine: 0, jail: 3, jail_max: 6, punishment: "лишение свободы на срок от 3 до 6 лет" },
    { article: "112", title: "Самоуправство", description: "Самоуправство, то есть самовольное, вопреки установленному законом или иным нормативным правовым актом порядку совершение каких-либо действий, правомерность которых оспаривается организацией или гражданином, если такими действиями причинен существенный вред – наказывается лишением свободы на срок от 2 до 5 лет.", fine: 0, jail: 2, jail_max: 5, punishment: "лишение свободы на срок от 2 до 5 лет" },
    { article: "113", title: "Неуплата штрафа либо отказ от его уплаты", description: "Неуплата или отказ от уплаты штрафа – наказывается лишением свободы на срок от 1 до 4 лет. (Примечание: неуплатой штрафа признается отсутствие в течении трех (3) минут активных действий направленных на его исполнение с момента выписки чека на оплату штрафа.)", fine: 0, jail: 1, jail_max: 4, punishment: "лишение свободы на срок от 1 до 4 лет" },
    ; ========== Глава 15. Преступления против военной службы ==========
    { article: "114", title: "Понятие преступлений против военной службы", description: "Преступлениями против военной службы признаются предусмотренные настоящей главой преступления против установленного порядка прохождения военной службы, совершенные военнослужащими, проходящими военную службу по призыву либо по контракту, а также гражданами, пребывающими в запасе.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "115.1", title: "Дезертирство", description: "Дезертирство, то есть самовольное оставление части или места службы в целях уклонения от прохождения военной службы, а равно неявка в тех же целях на службу – наказывается лишением свободы на срок от 5 до 10 лет.", fine: 0, jail: 5, jail_max: 10, punishment: "лишение свободы на срок от 5 до 10 лет" },
    { article: "115.2", title: "Дезертирство с оружием или группой лиц", description: "Дезертирство с оружием, вверенным по службе, а равно дезертирство, совершенное группой лиц по предварительному сговору или организованной группой – наказывается лишением свободы на срок от 8 до 13 лет.", fine: 0, jail: 8, jail_max: 13, punishment: "лишение свободы на срок от 8 до 13 лет" },
    { article: "115.3", title: "Дезертирство в военное время", description: "Деяния, предусмотренные частями первой или второй настоящей статьи, совершенные в период военного положения, в военное время либо в условиях вооруженного конфликта – наказывается лишением свободы на срок от 13 до 15 лет.", fine: 0, jail: 13, jail_max: 15, punishment: "лишение свободы на срок от 13 до 15 лет" },
    ; ========== Глава 16. Преступления против здоровья населения и общественной нравственности ==========
    { article: "116.1", title: "Незаконные приобретение, хранение, перевозка, изготовление наркотических средств без цели сбыта", description: "Незаконные приобретение, хранение, перевозка, изготовление, переработка без цели сбыта наркотических средств, психотропных веществ, их аналогов и прекурсоров наркотических средств в значительном размере, а также незаконные приобретение, хранение, перевозка без цели сбыта растений, содержащих наркотические средства, психотропные вещества или прекурсоры наркотических веществ, либо их частей, содержащих наркотические средства, психотропные вещества, либо прекурсоры наркотических или психотропных веществ – наказывается лишением свободы на срок от 2 до 7 лет со штрафом в размере от 10 тысяч до 25 тысяч рублей.", fine: 25000, jail: 2, jail_max: 7, punishment: "лишение свободы на срок от 2 до 7 лет со штрафом от 10 до 25 тыс. руб." },
    { article: "116.2", title: "Незаконные производство, сбыт или пересылка наркотических средств", description: "Незаконные производство, сбыт или пересылка наркотических средств, психотропных веществ или их аналогов, а также незаконные сбыт или пересылка растений, содержащих наркотические средства или психотропные вещества, либо их частей, содержащих наркотические средства или психотропные вещества – наказывается лишением свободы на срок от 4 до 9 лет со штрафом в размере от 25 тысяч до 45 тысяч рублей.", fine: 45000, jail: 4, jail_max: 9, punishment: "лишение свободы на срок от 4 до 9 лет со штрафом от 25 до 45 тыс. руб." },
    { article: "117", title: "Склонение к потреблению наркотических средств", description: "Склонение другого лица к потреблению наркотических средств, психотропных веществ или их аналогов – наказывается лишением свободы на срок от 3 до 6 лет.", fine: 0, jail: 3, jail_max: 6, punishment: "лишение свободы на срок от 3 до 6 лет" },
    { article: "118", title: "Незаконное культивирование растений, содержащих наркотические средства", description: "Незаконное культивирование растений, содержащих наркотические средства или психотропные вещества либо их прекурсоры – наказывается лишением свободы на срок от 5 до 9 лет.", fine: 0, jail: 5, jail_max: 9, punishment: "лишение свободы на срок от 5 до 9 лет" },
    { article: "119", title: "Организация либо содержание притонов", description: "Организация либо содержание притонов или систематическое предоставление помещений для потребления наркотических средств, психотропных веществ или их аналогов – наказывается лишением свободы на срок от 3 до 6 лет.", fine: 0, jail: 3, jail_max: 6, punishment: "лишение свободы на срок от 3 до 6 лет" },
    { article: "120", title: "Вовлечение в занятие проституцией", description: "Вовлечение в занятие проституцией или принуждение к продолжению занятия проституцией – наказывается штрафом в размере от 15 тысяч до 35 тысяч рублей, либо лишением свободы на срок от 2 до 5 лет.", fine: 35000, jail: 2, jail_max: 5, punishment: "штраф от 15 до 35 тыс. руб., либо лишение свободы от 2 до 5 лет" },
    ; ========== Глава 17. Заключительные положения ==========
    { article: "121", title: "Обязательность исполнения настоящего кодекса", description: "1. Настоящий кодекс обязателен для исполнения всеми судами, органами прокуратуры, следственными органами, правоохранительными органами, должностными лицами и гражданами на территории Региональной Федерации.`n2. Невыполнение либо нарушение требований настоящего кодекса влечет установленную законом ответственность.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "122", title: "Толкование норм настоящего кодекса", description: "1. Толкование положений настоящего кодекса осуществляется Верховным судом Региональной Федерации.`n2. Официальное разъяснение норм настоящего кодекса дается Премьер-министром Региональной Федерации либо уполномоченным им органом в пределах их компетенции.", fine: 0, jail: 0, jail_max: 0, punishment: "" },
    { article: "123", title: "Вступление в силу настоящего кодекса", description: "Настоящий кодекс вступает в силу со дня его официального опубликования.", fine: 0, jail: 0, jail_max: 0, punishment: "" }
]

